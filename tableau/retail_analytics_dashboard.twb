<?xml version='1.0' encoding='utf-8' ?>
<workbook source-platform="mac" version="18.1">
  <preferences>
    <preference name="ui.encoding.shelf.height" value="24" />
    <preference name="ui.shelf.height" value="26" />
  </preferences>
  <datasources>

  <datasource caption="rfm_segments" inline="true" name="rfm_segments" version="18.1">
    <connection class="textscan" directory="Data" filename="rfm_segments.csv" header="yes" separator=",">
      <relation name="rfm_segments.csv" table="[rfm_segments#csv]" type="table" />
    </connection>
    <column caption="segment" datatype="string" name="[segment]" role="dimension" type="nominal" />
      <column caption="households" datatype="real" name="[households]" role="measure" type="quantitative" />
      <column caption="avg_recency_days" datatype="real" name="[avg_recency_days]" role="measure" type="quantitative" />
      <column caption="median_recency_days" datatype="real" name="[median_recency_days]" role="measure" type="quantitative" />
      <column caption="avg_frequency_baskets" datatype="real" name="[avg_frequency_baskets]" role="measure" type="quantitative" />
      <column caption="median_frequency_baskets" datatype="real" name="[median_frequency_baskets]" role="measure" type="quantitative" />
      <column caption="avg_monetary_sales" datatype="real" name="[avg_monetary_sales]" role="measure" type="quantitative" />
      <column caption="median_monetary_sales" datatype="real" name="[median_monetary_sales]" role="measure" type="quantitative" />
      <column caption="total_sales" datatype="real" name="[total_sales]" role="measure" type="quantitative" />
      <column caption="avg_basket_value" datatype="real" name="[avg_basket_value]" role="measure" type="quantitative" />
      <column caption="avg_discount_to_sales" datatype="real" name="[avg_discount_to_sales]" role="measure" type="quantitative" />
      <column caption="household_share_pct" datatype="real" name="[household_share_pct]" role="measure" type="quantitative" />
      <column caption="top_classification_1_distribution" datatype="string" name="[top_classification_1_distribution]" role="dimension" type="nominal" />
      <column caption="top_classification_2_distribution" datatype="string" name="[top_classification_2_distribution]" role="dimension" type="nominal" />
      <column caption="top_classification_3_distribution" datatype="string" name="[top_classification_3_distribution]" role="dimension" type="nominal" />
      <column caption="top_classification_4_distribution" datatype="string" name="[top_classification_4_distribution]" role="dimension" type="nominal" />
      <column caption="top_classification_5_distribution" datatype="string" name="[top_classification_5_distribution]" role="dimension" type="nominal" />
      <column caption="top_HOMEOWNER_DESC_distribution" datatype="string" name="[top_HOMEOWNER_DESC_distribution]" role="dimension" type="nominal" />
      <column caption="top_KID_CATEGORY_DESC_distribution" datatype="string" name="[top_KID_CATEGORY_DESC_distribution]" role="dimension" type="nominal" />
  </datasource>

  <datasource caption="promotion_roi" inline="true" name="promotion_roi" version="18.1">
    <connection class="textscan" directory="Data" filename="promotion_roi.csv" header="yes" separator=",">
      <relation name="promotion_roi.csv" table="[promotion_roi#csv]" type="table" />
    </connection>
    <column caption="campaign" datatype="real" name="[campaign]" role="measure" type="quantitative" />
      <column caption="promotion_type" datatype="string" name="[promotion_type]" role="dimension" type="nominal" />
      <column caption="start_day" datatype="real" name="[start_day]" role="measure" type="quantitative" />
      <column caption="end_day" datatype="real" name="[end_day]" role="measure" type="quantitative" />
      <column caption="window_days" datatype="real" name="[window_days]" role="measure" type="quantitative" />
