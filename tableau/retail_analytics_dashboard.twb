  <worksheets>

  <worksheet name="RFM Segment Distribution">
    <table>
      <view>
        <datasources>
          <datasource caption="rfm_segments" name="rfm_segments" />
        </datasources>
        <aggregation value="true" />
      </view>
      <style />
      <panes>
        <pane>
          <mark class="Bar" />
        </pane>
      </panes>
      <rows>[rfm_segments].[segment]</rows>
      <cols>SUM([rfm_segments].[households])</cols>
    </table>
  </worksheet>

  <worksheet name="Promotion ROI Ranking">
    <table>
      <view>
        <datasources>
          <datasource caption="promotion_roi" name="promotion_roi" />
        </datasources>
        <aggregation value="true" />
      </view>
      <style />
      <panes>
        <pane>
          <mark class="Bar" />
        </pane>
      </panes>
      <rows>[promotion_roi].[campaign]</rows>
      <cols>SUM([promotion_roi].[incremental_revenue])</cols>
    </table>
  </worksheet>

  <worksheet name="Basket Affinity Lift">
    <table>
      <view>
        <datasources>
          <datasource caption="basket_affinity" name="basket_affinity" />
        </datasources>
        <aggregation value="true" />
      </view>
      <style />
      <panes>
        <pane>
          <mark class="Bar" />
        </pane>
      </panes>
      <rows>[basket_affinity].[category_affinity]</rows>
      <cols>SUM([basket_affinity].[lift])</cols>
    </table>
  </worksheet>

  <worksheet name="Targeting Recommendation Revenue">
    <table>
      <view>
        <datasources>
          <datasource caption="targeting_recommendation" name="targeting_recommendation" />
        </datasources>
        <aggregation value="true" />
      </view>
      <style />
      <panes>
        <pane>
          <mark class="Bar" />
        </pane>
      </panes>
      <rows>[targeting_recommendation].[segment]</rows>
      <cols>SUM([targeting_recommendation].[estimated_incremental_revenue])</cols>
    </table>
  </worksheet>

  <worksheet name="Coupon Strategy Mix">
    <table>
      <view>
        <datasources>
          <datasource caption="coupon_dependency" name="coupon_dependency" />
        </datasources>
        <aggregation value="true" />
      </view>
      <style />
      <panes>
        <pane>
          <mark class="Bar" />
        </pane>
      </panes>
      <rows>[coupon_dependency].[segment]</rows>
      <cols>SUM([coupon_dependency].[coupon_households])</cols>
    </table>
  </worksheet>
  </worksheets>
  <dashboards>
    <dashboard name="Retail Analytics Overview">
      <style />
      <size maxheight="1100" maxwidth="1200" minheight="1100" minwidth="1200" />
      <zones>
        <zone h="1100" id="1" type="layout-flow" w="1200" x="0" y="0">
          <zone h="450" id="2" name="RFM Segment Distribution" type="worksheet" w="600" x="0" y="0" />
          <zone h="450" id="3" name="Promotion ROI Ranking" type="worksheet" w="600" x="600" y="0" />
          <zone h="450" id="4" name="Basket Affinity Lift" type="worksheet" w="600" x="0" y="450" />
          <zone h="450" id="5" name="Targeting Recommendation Revenue" type="worksheet" w="600" x="600" y="450" />
          <zone h="200" id="6" name="Coupon Strategy Mix" type="worksheet" w="1200" x="0" y="900" />
        </zone>
      </zones>
    </dashboard>
  </dashboards>
</workbook>
