      <column caption="control_revenue" datatype="real" name="[control_revenue]" role="measure" type="quantitative" />
      <column caption="treatment_revenue_per_household" datatype="real" name="[treatment_revenue_per_household]" role="measure" type="quantitative" />
      <column caption="control_revenue_per_household" datatype="real" name="[control_revenue_per_household]" role="measure" type="quantitative" />
      <column caption="treatment_buyer_rate" datatype="real" name="[treatment_buyer_rate]" role="measure" type="quantitative" />
      <column caption="control_buyer_rate" datatype="real" name="[control_buyer_rate]" role="measure" type="quantitative" />
