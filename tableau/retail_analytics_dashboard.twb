  </datasource>

  <datasource caption="targeting_recommendation" inline="true" name="targeting_recommendation" version="18.1">
    <connection class="textscan" directory="Data" filename="targeting_recommendation.csv" header="yes" separator=",">
      <relation name="targeting_recommendation.csv" table="[targeting_recommendation#csv]" type="table" />
