      <column caption="campaign_products" datatype="real" name="[campaign_products]" role="measure" type="quantitative" />
      <column caption="treatment_revenue_per_household" datatype="real" name="[treatment_revenue_per_household]" role="measure" type="quantitative" />
      <column caption="control_revenue_per_household" datatype="real" name="[control_revenue_per_household]" role="measure" type="quantitative" />
      <column caption="treatment_pre_revenue_per_household_scaled" datatype="real" name="[treatment_pre_revenue_per_household_scaled]" role="measure" type="quantitative" />
      <column caption="control_pre_revenue_per_household_scaled" datatype="real" name="[control_pre_revenue_per_household_scaled]" role="measure" type="quantitative" />
      <column caption="treatment_buyer_rate" datatype="real" name="[treatment_buyer_rate]" role="measure" type="quantitative" />
